# ── Operalyn Frontend ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# In development leave both blank (Vite proxy handles routing).
# In production set both to your live URLs.

# Laravel API base URL (no trailing slash)
# Dev:  leave blank (proxied to localhost:8000 by Vite)
# Prod: https://api.operalyn.com
VITE_API_URL=

# Node.js chat server URL (no trailing slash)
# Dev:  leave blank → defaults to http://localhost:3001
# Prod: https://socket.operalyn.com
VITE_CHAT_URL=
